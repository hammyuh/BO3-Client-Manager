<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>BO3ClientManager</AssemblyName>
    <GenerateAssemblyInfo>False</GenerateAssemblyInfo>
    <OutputType>WinExe</OutputType>
    <UseWPF>True</UseWPF>
    <TargetFramework>net10.0-windows</TargetFramework>
    <PlatformTarget>x64</PlatformTarget>
    <Nullable>enable</Nullable>
    <NoWarn>$(NoWarn);CS8600;CS8604</NoWarn>
  </PropertyGroup>
  <PropertyGroup>
    <AllowUnsafeBlocks>True</AllowUnsafeBlocks>
    <CheckForOverflowUnderflow>False</CheckForOverflowUnderflow>
  </PropertyGroup>
  <PropertyGroup>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <RootNamespace>BO3ClientManager</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <None Remove="resources\bo3.ico" />
    <None Remove="resources\bo3.png" />
    <None Remove="resources\ezz.png" />
    <None Remove="resources\splash.png" />
    <Resource Include="resources\bo3.ico" />
    <Resource Include="resources\bo3.png" />
    <Resource Include="resources\ezz.png" />
    <Resource Include="resources\splash.png" />
  </ItemGroup>
  <ItemGroup />
</Project>
