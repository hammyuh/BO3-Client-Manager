<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="BO3ClientManager.ActivityLogPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Activity Log" xmlns:t7_hub="clr-namespace:BO3ClientManager">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <Style x:Key="LogTextStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="#FFD8E0F2" />
        <Style.Triggers>
          <DataTrigger Value="Warning" Binding="{Binding Level}">
            <Setter Property="Foreground" Value="#FFFFD66B" />
          </DataTrigger>
          <DataTrigger Value="Error" Binding="{Binding Level}">
            <Setter Property="Foreground" Value="#FFFF7272" />
          </DataTrigger>
          <DataTrigger Value="Success" Binding="{Binding Level}">
            <Setter Property="Foreground" Value="#FF7CFF9D" />
          </DataTrigger>
        </Style.Triggers>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Margin="30">
    <Border Width="650" Padding="30" CornerRadius="14" Background="#E6191E2A" HorizontalAlignment="Center" VerticalAlignment="Center">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="12" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="Activity Log" Foreground="#FFFFFFFF" FontSize="30" FontWeight="SemiBold" />
        <ListBox Name="LogList" Grid.Row="2" Height="330" Background="#FF171C27" BorderBrush="#FF4B5670" BorderThickness="1" FontFamily="Consolas" FontSize="12" Padding="8">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal">
                <TextBlock Style="{StaticResource LogTextStyle}" Margin="0,0,10,0" Text="{Binding Timestamp}" />
                <TextBlock Margin="0,0,10,0" Text="{Binding Level}">
                  <FrameworkElement.Style>
                    <Style BasedOn="{StaticResource LogTextStyle}" TargetType="{x:Type TextBlock}" />
                  </FrameworkElement.Style>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Text="{Binding Message}">
                  <FrameworkElement.Style>
                    <Style BasedOn="{StaticResource LogTextStyle}" TargetType="{x:Type TextBlock}" />
                  </FrameworkElement.Style>
                </TextBlock>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
          <Button Width="95" Content="Refresh" Click="RefreshButton_Click" />
          <Button Width="95" Content="Back" Click="BackButton_Click" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Page>
