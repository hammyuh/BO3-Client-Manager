<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="BO3ClientManager.UpdatePromptWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="BO3 Client Manager Update" Width="470" Height="240" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None" Background="#00FFFFFF" AllowsTransparency="True" Opacity="0" xmlns:t7_hub="clr-namespace:BO3ClientManager">
  <Border CornerRadius="16" Background="#EE171C27" BorderBrush="#FF4B5670" BorderThickness="1" Padding="24" MinHeight="192">
    <StackPanel>
      <TextBlock Text="Update Available" Foreground="#FFFFFFFF" FontSize="26" FontWeight="SemiBold" />
      <TextBlock Name="MessageText" Foreground="#FFD8E0F2" FontSize="14" TextWrapping="Wrap" Margin="0,14,0,0" />
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,28,0,0">
        <Button Width="150" Height="40" Content="Open Release" Click="OpenRelease_Click" />
        <Button Width="160" Height="40" Content="Remind Me Later" Click="RemindLater_Click" />
      </StackPanel>
    </StackPanel>
  </Border>
</Window>
