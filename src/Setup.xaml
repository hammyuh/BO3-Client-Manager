<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="BO3ClientManager.Setup" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Setup" xmlns:t7_hub="clr-namespace:BO3ClientManager">
  <Grid Margin="30">
    <Border Width="650" Padding="35" CornerRadius="15" Background="#AA1C1C1C" HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel>
        <TextBlock Text="Welcome to BO3 Client Manager" Foreground="#FFFFFFFF" FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Center" />
        <Border Background="#442C5EAA" CornerRadius="8" Padding="14" Margin="0,20,0,5">
          <StackPanel>
            <TextBlock Text="Setup checklist" Foreground="#FFFFFFFF" FontSize="16" FontWeight="Bold" />
            <TextBlock Text="1. Open the client folder and place each client in its matching directory." Foreground="#FFD8E0F2" Margin="0,7,0,0" TextWrapping="Wrap" />
            <TextBlock Text="2. Add the verified stock EXE; add the old EXE only if you use Ezz BOIII." Foreground="#FFD8E0F2" Margin="0,4,0,0" TextWrapping="Wrap" />
            <TextBlock Text="3. Remove any existing client files from BO3, then continue when the list is ready." Foreground="#FFD8E0F2" Margin="0,4,0,0" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
        <TextBlock Text="Black Ops III Installation:" Foreground="#FFFFFFFF" FontSize="18" FontWeight="Bold" Margin="0,20,0,10" />
        <StackPanel Orientation="Horizontal">
          <TextBox Name="BO3PathTB" Width="260" Height="35" VerticalContentAlignment="Center" />
          <Button Name="BrowseButton" Width="90" Height="35" Margin="10,0,0,0" Content="Browse" Click="BrowseButton_Click" />
          <Button Name="LocateButton" Width="110" Height="35" Margin="10,0,0,0" Content="Auto Locate" Click="LocateButton_Click" />
        </StackPanel>
        <TextBlock Text="Client List:" Foreground="#FFFFFFFF" FontSize="18" FontWeight="Bold" Margin="0,20,0,10" />
        <Border Background="#222222" CornerRadius="8" Padding="10">
          <UniformGrid Name="ClientList" Columns="3" Rows="3" />
        </Border>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
          <Button Name="OpenFolderButton" Width="170" Height="45" Margin="5" Content="Open Client Folder" Click="OpenFolderButton_Click" />
          <Button Name="ContinueButton" Width="170" Height="45" Margin="5" Content="Continue" Click="ContinueButton_Click" />
          <Button Name="RestoreBackupButton" Width="170" Height="45" Margin="5" Content="Restore Backup" Click="RestoreBackupButton_Click" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</Page>
